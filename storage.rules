rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ===== LECTURE PUBLIQUE pour tous les fichiers =====
    // Les documents sont accessibles en téléchargement sans connexion
    match /{allPaths=**} {
      allow read: if true;

      // ===== ÉCRITURE : admin connecté uniquement =====
      // Types acceptés : PDF, Word, images
      // Taille max : 50 Mo
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024
                   && (
                     request.resource.contentType.matches('application/pdf')
                     || request.resource.contentType.matches('application/vnd\\.openxmlformats.*')
                     || request.resource.contentType.matches('application/msword')
                     || request.resource.contentType.matches('image/.*')
                   );

      // Suppression : admin connecté uniquement
      allow delete: if request.auth != null;
    }
  }
}
