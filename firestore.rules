rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== LECTURE PUBLIQUE sur toutes les collections =====
    // La commission ANAQ et les visiteurs peuvent lire sans connexion
    match /{document=**} {
      allow read: if true;
    }

    // ===== ÉCRITURE RÉSERVÉE AUX ADMINISTRATEURS CONNECTÉS =====

    match /site_config/{docId} {
      allow write: if request.auth != null;
    }

    match /section1_contenu/{docId} {
      allow write: if request.auth != null;
    }

    match /section2_documents/{docId} {
      allow write: if request.auth != null;
    }

    match /memoires/{memoireId} {
      allow write: if request.auth != null;
    }

    match /galerie/{photoId} {
      allow write: if request.auth != null;
    }

    match /temoignages/{temoignageId} {
      allow write: if request.auth != null;
    }
  }
}
